#!/usr/bin/env bash
#MISE description="Render a coverage report with delta vs a base profile; posts a sticky PR comment in CI"
#
# Usage: mise run report:coverage <head-profile> [base-profile]
#
# Aggregates Go cover profiles per package and emits a markdown report to
# stdout. In GitHub Actions it also appends the report to the step summary,
# and when PR_NUMBER is set it upserts a sticky PR comment identified by a
# hidden marker (updated in place on subsequent pushes, never stacked).
#
# Portable to bash 3.2 (macOS): aggregation and joining live in awk.
set -euo pipefail

MARKER='<!-- healthchecksio-cli-coverage-bot:v1 -->'

head_profile="${1:?usage: coverage-report <head-profile> [base-profile]}"
base_profile="${2:-}"

module="$(go list -m)"

# Emit "package covered_statements total_statements" per package, aggregated
# from a cover profile. Package names are shortened relative to the module.
profile_by_package() {
  awk -v module="$module" 'NR > 1 {
    split($1, loc, ":")
    pkg = loc[1]
    sub(/\/[^\/]*$/, "", pkg)
    if (pkg == module) pkg = "."
    else sub(module "/", "", pkg)
    total[pkg] += $2
    if ($3 > 0) covered[pkg] += $2
  }
  END {
    for (p in total) printf "%s %d %d\n", p, covered[p], total[p]
  }' "$1" | sort
}

total_pct() { # summary-file -> "NN.N"
  awk '{ c += $2; t += $3 } END { if (t == 0) print "0.0"; else printf "%.1f", 100 * c / t }' "$1"
}

head_sum="$(mktemp)"
base_sum="$(mktemp)"
report="$(mktemp)"
trap 'rm -f "$head_sum" "$base_sum" "$report"' EXIT

profile_by_package "$head_profile" > "$head_sum"

have_base=0
if [[ -n "$base_profile" && -f "$base_profile" ]]; then
  profile_by_package "$base_profile" > "$base_sum"
  have_base=1
fi

{
  echo "$MARKER"
  echo "## Coverage"
  echo
  head_pct="$(total_pct "$head_sum")"
  if [[ "$have_base" == 1 ]]; then
    base_pct="$(total_pct "$base_sum")"
    total_delta="$(awk -v h="$head_pct" -v b="$base_pct" 'BEGIN {
      d = h - b
      if (d > 0.05)       printf "+%.1f 🟢", d
      else if (d < -0.05) printf "%.1f 🔻", d
      else                printf "±0.0"
    }')"
    echo "**Total: ${head_pct}%** (main: ${base_pct}%, ${total_delta})"
    echo
    echo "| Package | Coverage | main | Δ |"
    echo "|---|---:|---:|---:|"
  else
    echo "**Total: ${head_pct}%** (no main baseline available — delta omitted)"
    echo
    echo "| Package | Coverage |"
    echo "|---|---:|"
  fi

  # Join head and base per-package summaries on package name and format rows.
  awk -v have_base="$have_base" '
    function pct(c, t) { return t == 0 ? 0 : 100 * c / t }
    function dcell(h, b,   d) {
      d = h - b
      if (d > 0.05)  return sprintf("+%.1f 🟢", d)
      if (d < -0.05) return sprintf("%.1f 🔻", d)
      return "±0.0"
    }
    FNR == NR { hc[$1] = $2; ht[$1] = $3; seen[$1] = 1; next }
              { bc[$1] = $2; bt[$1] = $3; seen[$1] = 1 }
    END {
      for (p in seen) {
        if (have_base != 1)
          printf "| `%s` | %.1f%% |\n", p, pct(hc[p], ht[p])
        else if ((p in ht) && (p in bt))
          printf "| `%s` | %.1f%% | %.1f%% | %s |\n", p, pct(hc[p], ht[p]), pct(bc[p], bt[p]), dcell(pct(hc[p], ht[p]), pct(bc[p], bt[p]))
        else if (p in ht)
          printf "| `%s` | %.1f%% | — | new |\n", p, pct(hc[p], ht[p])
        else
          printf "| `%s` | — | %.1f%% | removed |\n", p, pct(bc[p], bt[p])
      }
    }' "$head_sum" "$base_sum" | sort
  echo
  echo "<sub>mode: atomic, coverpkg: ./... — generated by \`mise run report:coverage\`</sub>"
} > "$report"

cat "$report"

if [[ -n "${GITHUB_STEP_SUMMARY:-}" ]]; then
  cat "$report" >> "$GITHUB_STEP_SUMMARY"
fi

if [[ -n "${PR_NUMBER:-}" && -n "${GITHUB_REPOSITORY:-}" ]]; then
  existing="$(gh api "repos/${GITHUB_REPOSITORY}/issues/${PR_NUMBER}/comments" --paginate \
    --jq "[.[] | select(.body | startswith(\"${MARKER}\")) | .id] | first // empty")"
  if [[ -n "$existing" ]]; then
    gh api --method PATCH "repos/${GITHUB_REPOSITORY}/issues/comments/${existing}" -F "body=@${report}" > /dev/null
    echo "updated sticky coverage comment ${existing}" >&2
  else
    gh api --method POST "repos/${GITHUB_REPOSITORY}/issues/${PR_NUMBER}/comments" -F "body=@${report}" > /dev/null
    echo "created sticky coverage comment" >&2
  fi
fi
